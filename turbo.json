{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "!dist/**", "!.turbo/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false,
      "interruptible": true
    },
    "start": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": { "dependsOn": ["build"], "cache": false },
    "db:migrate": { "dependsOn": ["build"], "cache": false },
    "db:push": { "dependsOn": ["build"], "cache": false },
    "db:drop": { "dependsOn": ["build"], "cache": false },
    "db:studio": { "dependsOn": ["build"], "cache": false, "persistent": true }
  }
}
