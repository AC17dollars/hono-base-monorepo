{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "hono-base-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "scripts": {
    "build": "turbo run build",
    "build:backend-api": "turbo run build --filter=backend-api...",
    "dev": "turbo watch dev",
    "dev:backend-api": "turbo watch dev --filter=backend-api...",
    "dev:app": "turbo watch dev --filter=${APP:-backend-api}...",
    "dev:queue-worker": "turbo watch dev --filter=queue-worker...",
    "start": "turbo run start",
    "start:backend-api": "turbo run start --filter=backend-api...",
    "start:queue-worker": "turbo run start --filter=queue-worker...",
    "start:app": "turbo run start --filter=${APP:-backend-api}...",
    "test": "turbo run test",
    "db:generate": "turbo run build --filter=@repo/db && pnpm --filter @repo/db db:generate",
    "db:migrate": "turbo run build --filter=@repo/db && pnpm --filter @repo/db db:migrate",
    "db:push": "turbo run build --filter=@repo/db && pnpm --filter @repo/db db:push",
    "db:studio": "turbo run build --filter=@repo/db && pnpm --filter @repo/db db:studio",
    "db:migrate:revert": "pnpm --filter @repo/db db:drop",
    "auth:generate": "turbo run build --filter=@repo/auth... && pnpm --filter @repo/auth generate"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
