{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "Shared database client and schema",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs",
      "default": "./dist/schema.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "db:push": "dotenvx run --env-file=../../.env -- drizzle-kit push",
    "db:generate": "dotenvx run --env-file=../../.env -- drizzle-kit generate",
    "db:migrate": "dotenvx run --env-file=../../.env -- drizzle-kit migrate",
    "db:studio": "dotenvx run --env-file=../../.env -- drizzle-kit studio",
    "db:drop": "dotenvx run --env-file=../../.env -- drizzle-kit drop"
  },
  "dependencies": {
    "@repo/config": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
