{
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "Shared database client and schema",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs",
      "default": "./dist/schema.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "predb:dev:push": "pnpm build",
    "db:dev:push": "dotenvx run -- drizzle-kit push",
    "predb:generate": "pnpm build",
    "db:generate": "dotenvx run -- drizzle-kit generate",
    "predb:migrate": "pnpm build",
    "db:migrate": "dotenvx run -- drizzle-kit migrate",
    "db:studio": "dotenvx run -- drizzle-kit studio"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "tsdown": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
