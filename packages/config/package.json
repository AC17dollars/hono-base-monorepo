{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@repo/config",
  "version": "1.0.0",
  "description": "Validated environment configuration schemas for each app",
  "type": "module",
  "exports": {
    "./backend-api": {
      "types": "./dist/backend-api.d.mts",
      "import": "./dist/backend-api.mjs",
      "default": "./dist/backend-api.mjs"
    },
    "./queue": {
      "types": "./dist/queue.d.mts",
      "import": "./dist/queue.mjs",
      "default": "./dist/queue.mjs"
    },
    "./queue-worker": {
      "types": "./dist/queue-worker.d.mts",
      "import": "./dist/queue-worker.mjs",
      "default": "./dist/queue-worker.mjs"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.4.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  }
}
