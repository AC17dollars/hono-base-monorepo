{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@repo/auth",
  "version": "1.0.0",
  "description": "Shared authentication configuration",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "generate": "dotenvx run --env-file=../../.env -- pnpm dlx @better-auth/cli generate --config ./auth-cli.config.ts --output ../db/src/schema/external/auth-schema.ts --yes"
  },
  "dependencies": {
    "@repo/config": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/mail": "workspace:*",
    "better-auth": "^1.5.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*"
  }
}
