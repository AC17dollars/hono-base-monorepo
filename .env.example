# Base URL for the application
APP_URL=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=${APP_URL}

# Google SSO (optional - enables Google sign-in when provided)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hono-base

# Redis (for queue - used by backend-api to push jobs, queue-worker to process)
REDIS_URL=redis://localhost:6379

# SMTP / Mail Settings (used by queue-worker to send emails)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
